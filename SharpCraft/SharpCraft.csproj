<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <RootNamespace>SharpCraft</RootNamespace>
        <ApplicationIcon>game_icon.ico</ApplicationIcon>
    </PropertyGroup>

    <ItemGroup>
      <None Update="Textures/**">
        <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      </None>
      <None Update="Fonts/**">
        <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      </None>
      <None Update="Localization/**">
        <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      </None>

      <None Update="soft_oal.dll" Condition="'$(RuntimeIdentifier)' == 'win-x64'">
        <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      </None>

      <ProjectReference Include="..\SharpCraft.Engine\SharpCraft.Engine.csproj" />
      <ProjectReference Include="..\SharpCraft.Game\SharpCraft.Game.csproj" />
    </ItemGroup>

</Project>
